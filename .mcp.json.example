{
    "mcpServers": {
        "todoist": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "TODOIST_API_TOKEN=xxxxxxxxxxxxxxxxxxxx",
                "ghcr.io/koki-develop/todoist-mcp-server:latest"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
        },
        "dart-sdk": {
            "command": "npx",
            "args": ["-y", "@egyleader/dart-mcp-server"]
        },
        "bluesky": {
            "command": "npx",
            "args": ["-y", "mcp-server-bluesky"],
            "env": {
                "BLUESKY_USERNAME": "your_account.bsky.social",
                "BLUESKY_PASSWORD": "xxxx-xxxx-xxxx-xxxx"
            }
        },
        "atproto-dart-rag": {
            "command": "uvx",
            "args": ["mcp-server-qdrant"],
            "env": {
                "QDRANT_URL": "http://localhost:6333",
                "COLLECTION_NAME": "atproto-dart",
                "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
                "EMBEDDING_DIMENSION": "384",
                "TOP_K": "10",
                "TOOL_STORE_DESCRIPTION": "Store atproto.dart documentation, API references, and code examples.",
                "TOOL_FIND_DESCRIPTION": "Search for atproto.dart related information including API usage, method descriptions, implementation examples, and documentation."
            }
        },
        "moodesky-docs": {
            "command": "uvx",
            "args": ["mcp-server-qdrant"],
            "env": {
                "QDRANT_URL": "http://localhost:6333",
                "COLLECTION_NAME": "moodeSky",
                "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
                "EMBEDDING_DIMENSION": "384",
                "TOP_K": "10",
                "TOOL_STORE_DESCRIPTION": "Store moodeSky Flutter app documentation, code structure, and implementation details.",
                "TOOL_FIND_DESCRIPTION": "Search for moodeSky Flutter app related information including widgets, providers, services, database models, UI components, and business logic."
            }
        },
        "flutter-docs": {
            "command": "uvx",
            "args": ["mcp-server-qdrant"],
            "env": {
                "QDRANT_URL": "http://localhost:6333",
                "COLLECTION_NAME": "flutter-docs",
                "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
                "EMBEDDING_DIMENSION": "384",
                "TOP_K": "10",
                "TOOL_STORE_DESCRIPTION": "Store Flutter official documentation, guides, widget references, and examples.",
                "TOOL_FIND_DESCRIPTION": "Search for Flutter official documentation including widgets, APIs, tutorials, guides, best practices, and examples."
            }
        },
        "tavily": {
            "command": "npx",
            "args": ["-y", "mcp-server-tavily"],
            "env": {
                "TAVILY_API_KEY": "your_tavily_api_key_here"
            }
        },
        "context7": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp"]
        },
        "github": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/",
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
            }
        }
    }
}